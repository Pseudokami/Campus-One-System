{
  "name": "campus-one-institution-be",
  "version": "1.0.0",
  "description": "Campus One — Institution Admin Backend",
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "dev": "concurrently --names \"main,auth,institution,data\" --prefix-colors \"blue,white,gray,green\" \"ts-node -r tsconfig-paths/register src/main.ts\" \"ts-node -r tsconfig-paths/register apps/auth-service/src/main.ts\" \"ts-node -r tsconfig-paths/register apps/institution-service/src/main.ts\" \"ts-node -r tsconfig-paths/register apps/institution-data-service/src/main.ts\"",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:auth": "ts-node -r tsconfig-paths/register apps/auth-service/src/main.ts",
    "dev:institution": "ts-node -r tsconfig-paths/register apps/institution-service/src/main.ts",
    "dev:data": "ts-node -r tsconfig-paths/register apps/institution-data-service/src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^16.0.0",
    "file-type": "^22.0.1",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.0"
  },
  "private": true
}
